{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Node",
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,

    "baseUrl": "./src",

    "types": ["vite/client"],

    "ignoreDeprecations": "5.0"
  },
  "include": ["src", "tailwind.config.ts", "postcss.config.cjs"]
}
